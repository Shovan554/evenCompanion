{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "noEmit": true,
    "types": ["node"],
    "outDir": "dist"
  },
  "include": ["src", "test"]
}
